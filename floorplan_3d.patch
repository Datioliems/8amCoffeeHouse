+    }
+
+    // ── SHARED ─────────────────────────────────────────────────
+    private function tablesJson(?string $branch)
+    {
+        $counts = $this->orderCounts($branch);
+        $bans = Ban::where('ma_chi_nhanh', $branch)->orderBy('so_ban')->get();
+
+        return response()->json($bans->map(fn ($b) => [
+            'ma_ban'     => $b->ma_ban,
+            'so_ban'     => $b->so_ban,
+            'vi_tri'     => $b->vi_tri,
+            'trang_thai' => $b->trang_thai,
