+
+            Ban::where('ma_ban', $to)->update(['trang_thai' => 'co_khach']);
+
+            $conLai = DB::table('ORDERS')
+                ->where('ma_ban', $from)
+                ->whereIn('trang_thai', self::ACTIVE_ORDER)
+                ->count();
+            Ban::where('ma_ban', $from)->update(['trang_thai' => $conLai ? 'co_khach' : 'trong']);
+        });
+
+        return response()->json(['ok' => true]);
