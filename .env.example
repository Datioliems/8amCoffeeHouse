APP_NAME="8AM Coffee & Roastery"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=8am_coffee
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS=no-reply@8am.coffee
MAIL_FROM_NAME="8AM Coffee"

# ── AN TOÀN THÔNG TIN ──────────────────────────────────────────
# Chống brute-force đăng nhập
LOGIN_MAX_ATTEMPTS=5          # số lần nhập sai trước khi khoá tài khoản
LOGIN_LOCKOUT_MINUTES=10      # thời gian khoá (phút)
LOGIN_IP_RATE=20              # số request /phút /IP tới /login
# Xác thực 2 lớp (OTP qua email). Bật =true cần MAIL_* hoạt động.
TWO_FACTOR_ENABLED=false
OTP_MINUTES=5
OTP_MAX_ATTEMPTS=5

# ── VNPAY (sandbox) ────────────────────────────────────────────
# Đăng ký tại https://sandbox.vnpayment.vn để lấy TmnCode + HashSecret.
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
# Để trống = tự dùng route payment.vnpay.return theo APP_URL.
VNPAY_RETURN_URL=
VNPAY_EXPIRE_MINUTES=15
